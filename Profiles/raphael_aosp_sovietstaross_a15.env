CONFIG_ENV=Profiles/raphael_aosp_sovietstaross_a15.env

DEVICE_NAME=redmi_k20pro_cn
DEVICE_CODENAME=raphael
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-  
CLANG_TRIPLE_ARM32=arm-linux-gnueabi-
CC=clang
EXTRA_CMDS:LLVM=1 LLVM_IAS=1 LD=ld.lld

KERNEL_SOURCE=https://github.com/diudiuyc520/crux-marisa00.git
KERNEL_BRANCH=ksu

DEFCONFIG_SOURCE=
DEFCONFIG_NAME=raphael_defconfig

KERNELSU_SOURCE=https://github.com/rsuntk/KernelSU.git
KERNELSU_BRANCH=susfs-v1.5.7
KERNELSU_NAME=KernelSU

SUSFS_ENABLE=true
SUSFS_FIXED=true

AK3_SOURCE=https://github.com/SOVIET-ANDROID/AnyKernel3.git
AK3_BRANCH=master

ROM_TEXT=Based-AOSP-ROM-Android15
